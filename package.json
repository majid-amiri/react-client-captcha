{
  "name": "react-client-captcha",
  "version": "1.0.3",
  "description": "",
  "author": "Majid Amiri",
  "license": "MIT",
  "repository": "majid-amiri/react-client-captcha",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "jsnext:main": "dist/index.es.js",
  "scripts": {
    "test": "yarn test:coverage && yarn build && yarn size && yarn docz:build",
    "test:coverage": "jest __tests__ --coverage",
    "docz:dev": "docz dev",
    "docz:build": "docz build",
    "build": "rollup -c",
    "start": "rollup -c -w",
    "size": "size-limit",
    "prettier": "prettier --write \"**/*.{js,ts,tsx,css,scss,json,md,mdx}\"",
    "generate-props": "node scripts/generateReactPropsTable.js src/index.js && yarn prettier",
    "deploy-storybook": "storybook-to-ghpages -- --out=docs",
    "dev": "start-storybook"
  },
  "jest": {
    "setupFilesAfterEnv": [
      "./__tests__/setupTests.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/dev/",
      "<rootDir>/__tests__/setupTests.js"
    ],
    "moduleNameMapper": {
      "\\.(css)$": "identity-obj-proxy"
    },
    "coverageDirectory": "./coverage/",
    "collectCoverage": true
  },
  "peerDependencies": {
    "prop-types": "^15.7.2",
    "react": "^16.9.0",
    "react-dom": "^16.9.0"
  },
  "devDependencies": {
    "@babel/cli": "7.10.4",
    "@babel/core": "7.10.4",
    "@babel/preset-env": "7.10.4",
    "@babel/preset-react": "7.10.4",
    "@rollup/plugin-babel": "^5.0.4",
    "@size-limit/preset-small-lib": "^4.5.3",
    "@storybook/addon-actions": "^5.3.19",
    "@storybook/addon-knobs": "^5.3.19",
    "@storybook/cli": "^5.3.19",
    "@storybook/react": "^5.3.19",
    "@storybook/storybook-deployer": "^2.8.6",
    "@svgr/rollup": "^2.4.1",
    "babel-eslint": "10.1.0",
    "babel-jest": "26.1.0",
    "babel-loader": "8.1.0",
    "babel-plugin-external-helpers": "6.22.0",
    "babel-polyfill": "6.26.0",
    "codecov": "^3.5.0",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.2",
    "eslint": "^7.4.0",
    "eslint-config-airbnb": "^18.2.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-react": "^7.20.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^26.1.0",
    "jest-canvas-mock": "^2.2.0",
    "jest-enzyme": "^7.1.2",
    "prettier": "^2.0.5",
    "react": "^16.13.1",
    "react-docgen": "^5.3.0",
    "react-dom": "^16.13.1",
    "rollup": "^2.21.0",
    "rollup-plugin-copy": "^3.3.0",
    "rollup-plugin-peer-deps-external": "^2.2.3",
    "rollup-plugin-postcss": "^3.1.2",
    "rollup-plugin-terser": "^6.1.0",
    "storybook": "^5.3.19"
  },
  "files": [
    "dist"
  ],
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "2 KB"
    }
  ]
}
